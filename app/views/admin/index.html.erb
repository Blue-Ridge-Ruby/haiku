<section>
  <div class="max-w-5xl mx-auto px-8 pb-16">
    <h1 class="text-2xl font-medium text-white mb-6">Admin — All Submissions</h1>

    <div class="space-y-4">
      <% @submissions.each do |submission| %>
        <div class="rounded-xl p-6 <%= submission.discarded? ? 'bg-red-900/40' : 'bg-white' %>" style="<%= submission.discarded? ? '' : 'background: linear-gradient(180deg, rgba(100, 184, 242, 0.2) 0%, rgba(255, 255, 255, 0.2) 29.69%), #FFFFFF; box-shadow: 0px 10px 10px rgba(38, 114, 181, 0.5);' %>">
          <div class="flex justify-between items-start">
            <div>
              <p class="text-sm <%= submission.discarded? ? 'text-gray-300' : 'text-gray-500' %> mb-2">
                <strong><%= submission.user.github_username %></strong>
                (<%= submission.user.github_email %>)
                &middot; <%= time_ago_in_words(submission.created_at) %> ago
                &middot; <strong><%= submission.votes.size %></strong> vote<%= submission.votes.size == 1 ? "" : "s" %>
                <% if submission.discarded? %>
                  <span class="text-red-400 font-medium">— discarded</span>
                <% end %>
              </p>
              <p class="<%= submission.discarded? ? 'text-gray-300' : 'text-[#0C2866]' %> italic">
                <%= submission.line1 %><br>
                <%= submission.line2 %><br>
                <%= submission.line3 %>
              </p>
            </div>
            <div>
              <%= button_to submission.discarded? ? "Restore" : "Discard",
                  admin_toggle_discard_path(submission),
                  class: "text-sm px-3 py-1 rounded cursor-pointer #{submission.discarded? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}" %>
            </div>
          </div>
        </div>
      <% end %>

      <% if @submissions.empty? %>
        <p class="text-white/60 text-center">No submissions yet.</p>
      <% end %>
    </div>
  </div>
</section>
