<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Blue Ridge Ruby Haiku Giveaway" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Submit a haiku for a chance to win a ticket to Blue Ridge Ruby 2026!">
    <meta property="og:title" content="Blue Ridge Ruby Haiku Giveaway">
    <meta property="og:description" content="Submit a haiku for a chance to win a ticket to Blue Ridge Ruby 2026!">
    <meta property="og:type" content="website">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="stylesheet" href="https://use.typekit.net/bzt5uqd.css">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.webmanifest">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-mountains-fixed" style="background-image: url('<%= image_path('mountains.jpg') %>')">
    <nav class="max-w-5xl mx-auto px-8 py-10">
      <div class="flex items-center justify-between">
        <%= link_to root_path, class: "flex items-center" do %>
          <div class="shrink-0 mr-0.5">
            <%= image_tag "logo.svg", alt: "Blue Ridge Ruby", class: "h-10" %>
          </div>
        <% end %>

        <div class="flex items-center gap-x-3">
          <% if Current.user %>
            <% if Current.admin? %>
              <%= link_to "Admin", admin_path, class: "text-[#2672B5] px-3 py-1 font-medium" %>
            <% end %>
            <%= button_to "Log out", sign_out_path, method: :delete, class: "text-[#2672B5] px-3 py-1 font-medium bg-transparent border-0 cursor-pointer" %>
          <% else %>
            <%= button_to "Log in with GitHub", "/auth/github", data: { turbo: false }, class: "bg-[#C41C1C] bg-linear-to-t from-[#C41C1C] to-[#DD423E] text-white font-medium py-2 px-4 shadow-sm rounded-sm cursor-pointer" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% if flash[:notice] %>
      <div class="max-w-2xl mx-auto px-8 mb-4">
        <div class="p-3 bg-green-100 text-green-800 rounded-lg"><%= flash[:notice] %></div>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="max-w-2xl mx-auto px-8 mb-4">
        <div class="p-3 bg-red-100 text-red-800 rounded-lg"><%= flash[:alert] %></div>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>
  </body>
</html>
